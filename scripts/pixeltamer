#!/usr/bin/env bash
# pixeltamer — image generation dispatcher.
#
# Picks a backend (OpenAI API or codex CLI), auto-detects from env, and dispatches
# to the right helper script. First time it runs without config, walks you through
# a quick interactive setup.
#
# Subcommands:
#   generate  text -> image (default if no subcommand given)
#   edit      modify or inpaint a single image (API only)
#   compose   blend 2-16 reference images into one (API only)
#   batch     plan + generate multiple images with verification (multi-image flow)
#   config    re-run interactive setup
#   doctor    diagnose your install
#
# Run `pixeltamer <subcommand> --help` for per-command flags.

set -euo pipefail

prog="$(basename "$0")"
script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
config_dir="${XDG_CONFIG_HOME:-$HOME/.config}/pixeltamer"
config_file="$config_dir/config.json"

# --- helpers ----------------------------------------------------------------

_log()  { printf "%s\n" "$*" >&2; }
_die()  { _log "$prog: $*"; exit 1; }
_have() { command -v "$1" >/dev/null 2>&1; }

_have_api_key() {
  [[ -n "${OPENAI_IMAGE_API_KEY:-}" ]] || [[ -n "${OPENAI_API_KEY:-}" ]]
}

_have_codex() {
  # Note: `codex login status` writes its "Logged in" message to stderr in
  # current versions, so we redirect stderr into stdout before piping to grep.
  # Using `2>/dev/null` here would silently hide the very string we grep for.
  _have codex && codex login status 2>&1 | grep -qi "logged in"
}

# Self-heal exec permissions on sibling scripts. The `skills` CLI's file copy
# strips +x mode bits when it places files into ~/.claude/skills/, ~/.codex/skills/,
# etc. — so a fresh `npx skills add` or `npx skills update` leaves every script
# non-executable.
#
# As of the bash-invoke change below, NO sibling strictly needs +x anymore: the
# Python/Node helpers are run via `python3`/`node` and pixeltamer_codex.sh is run
# via `bash`. This repair is now belt-and-suspenders — it protects any FUTURE
# sibling that gets direct-exec'd, and keeps `pixeltamer doctor` able to report
# the count. The one file we still can't fix from here is the dispatcher itself
# (it must already be +x for this code to run); that's an upstream skills-CLI bug
# — see README / docs/dev-docs/troubleshooting.md for the manual one-liner.
# Returns the count of files repaired; caller decides whether to surface it.
_self_heal_perms() {
  local fixed=0 candidate
  for candidate in \
    "$script_dir/pixeltamer_codex.sh" \
    "$script_dir/pixeltamer_api.py" \
    "$script_dir/pixeltamer_codex_oauth.py" \
    "$script_dir/verify-images.mjs"
  do
    if [[ -f "$candidate" && ! -x "$candidate" ]]; then
      chmod +x "$candidate" 2>/dev/null && fixed=$((fixed + 1))
    fi
  done
  echo "$fixed"
}

_load_config() {
  # Load saved backend preference, if any.
  if [[ -f "$config_file" ]] && _have python3; then
    PIXELTAMER_BACKEND_PREF="$(python3 -c "
import json, sys
try:
  print(json.load(open('$config_file')).get('backend', ''))
except Exception:
  pass
")"
  fi
  PIXELTAMER_BACKEND_PREF="${PIXELTAMER_BACKEND_PREF:-auto}"
}

_save_config() {
  local backend="$1"
  mkdir -p "$config_dir"
  if _have python3; then
    python3 -c "
import json, os
cfg = {}
p = '$config_file'
if os.path.exists(p):
  try:
    cfg = json.load(open(p))
  except Exception:
    cfg = {}
cfg['backend'] = '$backend'
json.dump(cfg, open(p, 'w'), indent=2)
"
  else
    printf '{ "backend": "%s" }\n' "$backend" >"$config_file"
  fi
  _log "saved → $config_file"
}

_detect_backend() {
  # Resolve which backend to use right now, honoring (in order):
  #   1. --backend flag (already in $BACKEND_OVERRIDE)
  #   2. PIXELTAMER_BACKEND env var
  #   3. saved config preference
  #   4. auto: api if key set, else codex if logged in
  local choice="${BACKEND_OVERRIDE:-${PIXELTAMER_BACKEND:-${PIXELTAMER_BACKEND_PREF:-auto}}}"
  case "$choice" in
    api|openai)
      _have_api_key || _die "backend=api but no OPENAI_IMAGE_API_KEY/OPENAI_API_KEY set"
      echo "api"
      ;;
    codex)
      _have_codex || _die "backend=codex but codex CLI not installed or not logged in"
      echo "codex"
      ;;
    auto|"")
      if _have_api_key; then echo "api"
      elif _have_codex;   then echo "codex"
      else
        _die "no backend available. Run \`$prog config\` to set one up."
      fi
      ;;
    *)
      _die "unknown backend: $choice (expected api|codex|auto)"
      ;;
  esac
}

# --- subcommands ------------------------------------------------------------

cmd_generate() {
  local backend
  backend="$(_detect_backend)"
  case "$backend" in
    api)   exec python3 "$script_dir/pixeltamer_api.py" generate "$@" ;;
    # Invoke via `bash` (not direct exec) so a +x bit stripped by the skills CLI
    # copy can't break codex generation — matches how the py/node helpers run.
    codex) exec bash "$script_dir/pixeltamer_codex.sh" "$@" ;;
  esac
}

cmd_edit() {
  local backend
  backend="$(_detect_backend)"
  case "$backend" in
    api)
      exec python3 "$script_dir/pixeltamer_api.py" edit "$@"
      ;;
    codex)
      # Codex Responses API can edit, but it doesn't take a mask. If --mask
      # was passed, route through API instead with a clear-but-quiet handoff.
      local has_mask=0
      for arg in "$@"; do
        if [[ "$arg" == "--mask" || "$arg" == --mask=* ]]; then
          has_mask=1
          break
        fi
      done
      if (( has_mask == 1 )); then
        _die "\`edit --mask\` requires the API backend (codex Responses API doesn't take a mask parameter). Set OPENAI_API_KEY or pass --backend api."
      fi
      exec python3 "$script_dir/pixeltamer_codex_oauth.py" edit "$@"
      ;;
  esac
}

cmd_compose() {
  local backend
  backend="$(_detect_backend)"
  case "$backend" in
    api)   exec python3 "$script_dir/pixeltamer_api.py" compose "$@" ;;
    codex) exec python3 "$script_dir/pixeltamer_codex_oauth.py" compose "$@" ;;
  esac
}

cmd_batch() {
  # Multi-image state-machine flow. Delegates to verify-images.mjs which
  # parses prompts.md, calls the right backend per entry, and verifies output.
  if ! _have node; then
    _die "\`batch\` needs Node.js 18+. Install from https://nodejs.org"
  fi
  exec node "$script_dir/verify-images.mjs" "$@"
}

cmd_config() {
  cat <<EOF >&2
$prog setup
==========
Pick how pixeltamer should generate images.

  [1] OpenAI API key       (fastest, full features, costs per image)
  [2] Codex CLI            (uses your ChatGPT subscription, no key required)
  [3] Auto-detect          (try API first, fall back to codex)  [recommended]
  [4] Cancel
EOF
  printf "your pick [3]: " >&2
  read -r choice
  case "${choice:-3}" in
    1) _save_config api ;;
    2) _save_config codex ;;
    3) _save_config auto ;;
    4) _log "cancelled."; exit 0 ;;
    *) _die "invalid choice: $choice" ;;
  esac

  echo >&2
  echo "Current backend status:" >&2
  if _have_api_key; then echo "  api    ✓ key present"; else echo "  api    ✗ set OPENAI_API_KEY"; fi >&2
  if _have_codex;   then echo "  codex  ✓ codex installed and logged in"; else echo "  codex  ✗ run: codex login"; fi >&2
}

cmd_doctor() {
  echo "$prog doctor"
  echo "=============="
  echo
  # Self-heal exec bits on siblings first — most "doctor reports codex/api as
  # missing" reports trace back to a non-executable helper that the dispatcher
  # silently couldn't invoke.
  local healed
  healed="$(_self_heal_perms)"
  if [[ "$healed" -gt 0 ]]; then
    echo "perms self-heal:    fixed +x on $healed script(s) in $script_dir"
    echo "                    (the skills CLI installer strips mode bits on copy)"
    echo
  fi
  # Check the dispatcher's own +x — we can only get here if it's executable,
  # but report it so users can copy/paste a one-liner if they hit the issue
  # on a sibling install path (project-level vs user-level skill dirs).
  if [[ ! -x "$script_dir/pixeltamer" ]]; then
    echo "dispatcher +x:      MISSING — run: chmod +x $script_dir/pixeltamer"
    echo
  fi
  echo "config file:        $config_file"
  if [[ -f "$config_file" ]]; then
    echo "config exists:      yes"
    [[ -r "$config_file" ]] && cat "$config_file" | sed 's/^/  /'
  else
    echo "config exists:      no  (run: $prog config)"
  fi
  echo
  echo "backend availability:"
  if _have_api_key; then
    echo "  api    ✓ OPENAI_*_KEY set"
  else
    echo "  api    ✗ no OPENAI_IMAGE_API_KEY or OPENAI_API_KEY"
  fi
  if _have codex; then
    if codex login status 2>&1 | grep -qi "logged in"; then
      echo "  codex  ✓ installed and logged in"
    else
      echo "  codex  ⚠ installed but not logged in (run: codex login)"
    fi
  else
    echo "  codex  ✗ not installed (npm install -g @openai/codex)"
  fi
  echo
  echo "runtime versions:"
  echo "  python3: $(python3 --version 2>&1 || echo 'missing')"
  echo "  node:    $(node --version 2>&1 || echo 'missing')"
  echo "  bash:    $BASH_VERSION"
}

usage() {
  cat <<EOF
$prog — image generation for Claude Code, Codex CLI, OpenCode, and friends.

usage:
  $prog [--backend api|codex|auto] <subcommand> [args...]

subcommands:
  generate (default)   text -> image
  edit                 modify a single image (mask requires API; OAuth path otherwise)
  compose              blend 2-16 reference images into one (API or codex-OAuth)
  batch                plan + generate multiple images with verification
  config               interactive setup
  doctor               diagnose install

shortcuts:
  $prog "make me a poster of X"     # = generate -p "..."
  $prog -p "X" -o image.png         # = generate

env:
  OPENAI_API_KEY / OPENAI_IMAGE_API_KEY     OpenAI API auth
  PIXELTAMER_BACKEND                         api | codex | auto
  OPENAI_IMAGE_BASE_URL                      override API base URL
  OPENAI_IMAGE_MODEL                         override model (default gpt-image-2)

run \`$prog <subcommand> --help\` for per-command flags.
EOF
}

# --- main -------------------------------------------------------------------

# Pull --backend off the front before subcommand dispatch.
BACKEND_OVERRIDE=""
if [[ "${1:-}" == "--backend" ]]; then
  BACKEND_OVERRIDE="${2:-}"
  shift 2
elif [[ "${1:-}" == --backend=* ]]; then
  BACKEND_OVERRIDE="${1#--backend=}"
  shift
fi

_load_config

# Silent self-heal of sibling script +x bits. The `skills` CLI installer copies
# files without preserving POSIX mode, so a fresh install leaves api/codex/oauth
# helpers non-executable. We've already proven we can run (the dispatcher is +x),
# so quietly fix siblings before any subcommand tries to exec them.
# Skip when subcommand is `doctor` — doctor does its own loud self-heal pass and
# we don't want to silently consume the signal it needs to report.
if [[ "${1:-}" != "doctor" && "${1:-}" != "diagnose" ]]; then
  _self_heal_perms >/dev/null 2>&1 || true
fi

# First-run nudge: if no config and no backend obviously available, prompt setup.
if [[ ! -f "$config_file" ]] && ! _have_api_key && ! _have_codex; then
  if [[ -t 0 && -t 1 ]]; then
    _log "$prog: no backend configured and no creds detected — running setup..."
    _log ""
    cmd_config
    _log ""
  fi
fi

# Dispatch
case "${1:-}" in
  ""|-h|--help|help)
    usage
    ;;
  generate|gen)
    shift
    cmd_generate "$@"
    ;;
  edit)
    shift
    cmd_edit "$@"
    ;;
  compose)
    shift
    cmd_compose "$@"
    ;;
  batch)
    shift
    cmd_batch "$@"
    ;;
  config|setup)
    shift
    cmd_config "$@"
    ;;
  doctor|diagnose)
    shift
    cmd_doctor "$@"
    ;;
  -p|--prompt|-i|--image|-o|--out|--size|--quality|-n|--style|--background|--format|--moderation|--user|--concurrency|--model|--mask)
    # Bare flags = implicit `generate`.
    cmd_generate "$@"
    ;;
  *)
    # Free-text first arg = treat as a generate prompt: `pixeltamer "make me X"`
    if [[ "$1" != -* ]]; then
      cmd_generate -p "$1" "${@:2}"
    else
      _die "unknown subcommand: $1 (try: $prog --help)"
    fi
    ;;
esac
